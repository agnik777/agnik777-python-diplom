# DATABASE_URL=postgres://user:password@localhost:5432/mydb

# MySQL
# DATABASE_URL=mysql://user:password@localhost:3306/mydb

YANDEX_APP_ID=ID
YANDEX_APP_SECRET=YANDEX_APP_SECRET

