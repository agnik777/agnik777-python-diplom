# .env.example
SECRET_KEY=django-insecure-your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=[]

MY_EMAIL=your-email@mail.ru
EMAIL_PASSWORD=your-email-password

# SQLite по умолчанию
DATABASE_URL=sqlite:///db.sqlite3

